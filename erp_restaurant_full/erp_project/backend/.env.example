# Backend environment — copy to ".env" for local (non-Docker) development.
# Prisma reads DATABASE_URL from here automatically.

# Point at your local Postgres (the docker-compose values are erp_user / erp_password / gwk_v7).
DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/gwk_v7?schema=public"

# Auth
JWT_SECRET="change_this_in_production_min_32_chars"
JWT_REFRESH_SECRET="change_this_refresh_secret_min_32"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Runtime
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:5173"
