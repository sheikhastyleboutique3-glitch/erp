# ── Backend env template — ONLY needed for bare-metal (PM2/node) runs. ──
# When running via Docker Compose, env comes from the ROOT .env instead;
# this file is ignored. For bare-metal: cp .env.example .env

# Bare-metal DB host is localhost (Postgres on the same machine)
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/gwk_v7

# Generate strong secrets: openssl rand -hex 32
JWT_SECRET=change_this_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=3000
NODE_ENV=production

# Exact browser origin, no trailing slash
ALLOWED_ORIGINS=http://72.62.36.204
